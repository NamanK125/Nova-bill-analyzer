# Nova trade-doc — environment config
# Copy to .env and edit. Loaded by pydantic-settings.

# ─── LLM provider switch ───────────────────────────────────────────────────
# "vllm"   → self-hosted, OpenAI-compatible (default; uses LLM_BASE_URL + VISION_MODEL)
# "openai" → api.openai.com (uses OPENAI_API_KEY + OPENAI_MODEL; assessor-only path)
LLM_PROVIDER=vllm

# ─── vLLM endpoint (active when LLM_PROVIDER=vllm) ─────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY   # vLLM ignores this but the openai client requires it

# OR split: uncomment to point vision and text at different vLLM instances
# VISION_BASE_URL=http://vision-gpu:8000/v1
# TEXT_BASE_URL=http://text-gpu:8001/v1

# ─── vLLM model names (as registered in vLLM --served-model-name) ──────────
VISION_MODEL=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
TEXT_MODEL=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
SMALL_TEXT_MODEL=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit   # router + NL→SQL; same model in dev

# Qwen3 family ships reasoning ("thinking") mode on by default — it emits
# <think>...</think> blocks that break response_format=json_object parsing.
# Leave true unless you switch back to Qwen2.5 or another non-Qwen3 model.
QWEN3_DISABLE_THINKING=true

# ─── OpenAI provider (active when LLM_PROVIDER=openai) ─────────────────────
# Assessor-only path. Set OPENAI_API_KEY, then set LLM_PROVIDER=openai above.
# We did not test this path end-to-end — gpt-4o-mini is multimodal so it should
# work via the same OpenAI client we already use for vLLM; the comparison doc
# at docs/MODEL_COMPARISON.md describes expected differences.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ─── Generation params ─────────────────────────────────────────────────────
EXTRACTOR_TEMPERATURE=0.0
VALIDATOR_TEMPERATURE=0.0
ROUTER_TEMPERATURE=0.2
NL_QUERY_TEMPERATURE=0.0

EXTRACTOR_MAX_TOKENS=2048
VALIDATOR_MAX_TOKENS=1024
ROUTER_MAX_TOKENS=512

# ─── Storage ───────────────────────────────────────────────────────────────
DB_URL=sqlite+aiosqlite:///./data/nova.db
DB_URL_SYNC=sqlite:///./data/nova.db
CHECKPOINT_DB=./data/checkpoints.db

# ─── App ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
SAMPLES_DIR=./samples
ARTIFACTS_DIR=./data/artifacts

# ─── Cost guardrails (per shipment) ────────────────────────────────────────
COST_BUDGET_USD=0.50
STAGE_TIMEOUT_EXTRACTOR_S=60
STAGE_TIMEOUT_VALIDATOR_S=20
STAGE_TIMEOUT_ROUTER_S=5
MAX_RETRIES_PER_STAGE=2

# ─── Confidence thresholds (Validator surfaces uncertain below these) ─────
CONFIDENCE_ACCEPT=0.95
CONFIDENCE_FLOOR=0.70


